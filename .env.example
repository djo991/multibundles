# MultiBundles - Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to source control.

# ─── Shopify App Credentials ──────────────────────────────────────────────────
# From your Partners dashboard → App → API credentials
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# Comma-separated OAuth scopes (must match shopify.app.toml)
SCOPES=read_products,write_products,read_inventory,write_inventory,read_orders,read_markets,write_markets

# The public URL of your app (ngrok tunnel in dev, production domain in prod)
SHOPIFY_APP_URL=https://your-app-url.ngrok.io

# Optional: if your development store uses a custom domain
# SHOP_CUSTOM_DOMAIN=mystore.example.com

# ─── Database ─────────────────────────────────────────────────────────────────
# Development: SQLite (default, no changes needed)
DATABASE_URL="file:./dev.sqlite"

# Production (Supabase PostgreSQL):
# 1. Create a project at https://supabase.com
# 2. Go to Project Settings → Database → Connection string → URI
# 3. Paste the connection string below (replace [YOUR-PASSWORD])
# DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── Node Environment ─────────────────────────────────────────────────────────
NODE_ENV=development
