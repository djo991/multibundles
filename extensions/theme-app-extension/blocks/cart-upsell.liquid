{% comment %}
  MultiBundles - Cart Upsell Embed Block
  ----------------------------------------
  Injects bundle upsell UI into the cart drawer via JavaScript.
  This is an App Embed Block (target: body) because the cart drawer
  does NOT support native App Blocks.

  The JS reads the current cart, checks for bundles that would give
  a better deal on items already in the cart, and shows upsell suggestions.

  Usage: Enable this App Embed in the Theme Customizer (Apps → MultiBundles Cart Upsell).
{% endcomment %}

<div
  id="multibundles-cart-upsell-root"
  data-shop="{{ shop.domain }}"
  data-currency="{{ cart.currency.iso_code }}"
  style="display:none"
>
  <div class="multibundles-upsell-panel">
    <button
      class="multibundles-upsell-close"
      aria-label="Close bundle suggestions"
      onclick="this.closest('#multibundles-cart-upsell-root').style.display='none'"
    >
      ×
    </button>
    <div class="multibundles-upsell-header">
      <p class="multibundles-upsell-title">
        {{ block.settings.heading | default: "Save more with a bundle" }}
      </p>
    </div>
    <div class="multibundles-upsell-content" id="multibundles-upsell-items">
      {%- comment -%}Populated by bundle-cart.js{%- endcomment -%}
    </div>
  </div>
</div>

<script
  src="{{ 'bundle-cart.js' | asset_url }}"
  defer
  data-upsell-heading="{{ block.settings.heading | escape }}"
  data-add-label="{{ block.settings.add_label | default: 'Add to cart' | escape }}"
></script>

{% schema %}
{
  "name": "MultiBundles Cart Upsell",
  "target": "body",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Upsell panel heading",
      "default": "Save more with a bundle"
    },
    {
      "type": "text",
      "id": "add_label",
      "label": "Add to cart button label",
      "default": "Add bundle"
    },
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Enable cart upsell",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Cart Upsell"
    }
  ]
}
{% endschema %}
