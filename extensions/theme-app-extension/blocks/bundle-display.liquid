{% comment %}
  MultiBundles - Bundle Display Block
  ------------------------------------
  Shows "What's in this bundle" for Fixed and Custom bundles.
  Reads the bundle-config metafield from the parent product.

  Usage: Add this App Block to the product page template in the Theme Customizer.
  Compatible with: Fixed bundles, Custom bundles (shows fixed components).
{% endcomment %}

{%- liquid
  assign bundle_config_raw = product.metafields["$app:multibundles"]["bundle-config"].value
  assign bundle_config = bundle_config_raw | parse_json
  assign bundle_type = bundle_config.type
-%}

{%- unless bundle_config and bundle_type == "fixed" or bundle_type == "custom" -%}
  {% comment %} Not a displayable bundle type — render nothing {% endcomment %}
  {%- break -%}
{%- endunless -%}

{%- assign components = bundle_config.components -%}
{%- if bundle_type == "custom" -%}
  {%- assign components = bundle_config.fixedComponents -%}
{%- endif -%}

{% if components.size > 0 %}
<div class="multibundles-display" data-bundle-type="{{ bundle_type }}">
  <div class="multibundles-display__header">
    <h2 class="multibundles-display__heading">{{ block.settings.heading }}</h2>
  </div>

  <div class="multibundles-display__items multibundles-display__items--{{ block.settings.layout }}">
    {% for component in components %}
      {%- assign variant = all_products | map: "variants" | flatten | where: "id", component.variantId | first -%}
      <div class="multibundles-display__item">
        {% if variant.image %}
          <div class="multibundles-display__item-image">
            <img
              src="{{ variant.image | image_url: width: 200 }}"
              alt="{{ variant.image.alt | escape }}"
              width="100"
              height="100"
              loading="lazy"
            >
          </div>
        {% endif %}
        <div class="multibundles-display__item-info">
          <p class="multibundles-display__item-title">{{ variant.product.title }}</p>
          {% if variant.title != "Default Title" %}
            <p class="multibundles-display__item-variant">{{ variant.title }}</p>
          {% endif %}
          {% if component.quantity > 1 %}
            <p class="multibundles-display__item-qty">Qty: {{ component.quantity }}</p>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

  {% if bundle_type == "custom" and bundle_config.selectablePool.pool.size > 0 %}
    <div class="multibundles-display__custom-note">
      <p>{{ block.settings.customizable_note | default: "Plus your choice of add-ons" }}</p>
    </div>
  {% endif %}
</div>
{% endif %}

{% schema %}
{
  "name": "Bundle Contents",
  "target": "section",
  "stylesheet": "bundle-display.css",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What's in this bundle"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "list", "label": "List" }
      ],
      "default": "grid"
    },
    {
      "type": "text",
      "id": "customizable_note",
      "label": "Customizable bundle note",
      "default": "Plus your choice of add-ons"
    }
  ]
}
{% endschema %}
